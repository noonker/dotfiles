#!/usr/bin/env bash
# Keep Deluge MIDI 1 <-> Carla wired, and Carla audio-out to the default sink.
# Re-runs on every PipeWire graph change; pw-link is a no-op if the link exists.
set -u

export PATH="$HOME/.guix-home/profile/bin:$PATH"

SINK_FALLBACK="alsa_output.pci-0000_c1_00.6.analog-stereo"

link() { pw-link "$1" "$2" >/dev/null 2>&1 || true; }

default_sink() {
  local s
  s=$(pactl get-default-sink 2>/dev/null) || s=""
  if [ -z "$s" ] || ! pw-link -i 2>/dev/null | grep -q "^${s}:playback_FL$"; then
    s="$SINK_FALLBACK"
  fi
  printf '%s' "$s"
}

reconnect() {
  local sink
  sink=$(default_sink)
  link "Deluge:Deluge MIDI 1" "Carla:events-in"
  link "Carla:events-out"     "Deluge:Deluge MIDI 1"
  link "Carla:audio-out1"     "${sink}:playback_FL"
  link "Carla:audio-out2"     "${sink}:playback_FR"
}

reconnect

# Wait for real graph topology changes, then reconnect.
#
# IMPORTANT: react only to Node add/remove events. pw-link and pactl
# themselves spawn short-lived pipewire Clients that show up in pw-mon
# as add/remove events — reacting to those creates a feedback loop
# (each reconnect fires ~5 pw-link/pactl calls, each generates more
# events, each event re-triggers reconnect). Result: ~60 graph
# reschedules/sec which causes audio glitches in Renoise/ALSA clients.
#
# The awk filter emits a tick only when an "added:" / "removed:" event
# is for an Interface:Node; the debounce after that collapses any
# burst (e.g. a USB device replug emitting multiple node events).
pw-mon 2>/dev/null \
  | awk '
      /^(added|removed):/   { ev=$1; next }
      ev && /PipeWire:Interface:Node / { print ev; fflush(); ev="" }
    ' \
  | while IFS= read -r _; do
      while IFS= read -r -t 0.5 _; do :; done
      reconnect
    done
