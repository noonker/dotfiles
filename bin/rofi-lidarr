#!/usr/bin/env bash
# Search Lidarr and add an album (auto-adding the artist if needed).
#
# Reads from `pass show Home/LidarrAPI`:
#   line 1: API key
#   url:    base URL
# Env overrides: ROFI_LIDARR_URL, ROFI_LIDARR_API_KEY
set -euo pipefail

PASS_DATA="$(pass show Home/LidarrAPI 2>/dev/null || true)"
pass_field() { printf '%s\n' "$PASS_DATA" | awk -v k="^$1:" 'tolower($0) ~ tolower(k) { sub(/^[^:]+:[[:space:]]*/, ""); print; exit }'; }

KEY="${ROFI_LIDARR_API_KEY:-$(printf '%s\n' "$PASS_DATA" | head -n1)}"
URL="${ROFI_LIDARR_URL:-$(pass_field url)}"
URL="${URL:-https://localhost:8686}"

err() { notify-send "rofi-lidarr" "$1" 2>/dev/null || echo "$1" >&2; }

[ -n "$KEY" ] || { err "no API key (set ROFI_LIDARR_API_KEY or run: pass insert Home/LidarrAPI)"; exit 1; }

api() { curl -fsS -H "X-Api-Key: $KEY" "$@"; }

query=$(rofi -dmenu -p "Lidarr search" </dev/null || true)
[ -n "$query" ] || exit 0

results=$(api -G --data-urlencode "term=$query" "$URL/api/v1/album/lookup") \
  || { err "lookup failed"; exit 1; }

choices=$(echo "$results" | jq -r '
  to_entries[] |
  "\(.value.artist.artistName // "?") — \(.value.title)\(if .value.disambiguation != "" and .value.disambiguation != null then " (\(.value.disambiguation))" else "" end)\t\(.key)"')

[ -n "$choices" ] || { err "no results"; exit 0; }

picked=$(printf '%s\n' "$choices" | rofi -dmenu -i -matching fuzzy -p "Add" \
  -display-columns 1 -display-column-separator '\t' || true)
[ -n "$picked" ] || exit 0

idx=$(printf '%s' "$picked" | awk -F'\t' '{print $NF}')

qpid=$(api "$URL/api/v1/qualityprofile" | jq '.[0].id')
mpid=$(api "$URL/api/v1/metadataprofile" | jq '.[0].id')
root=$(api "$URL/api/v1/rootfolder" | jq -r '.[0].path')

payload=$(echo "$results" | jq --argjson i "$idx" \
  --argjson q "$qpid" --argjson m "$mpid" --arg r "$root" '
  .[$i] + {
    monitored: true,
    addOptions: { searchForNewAlbum: true },
    artist: (.[$i].artist + {
      qualityProfileId: $q,
      metadataProfileId: $m,
      rootFolderPath: $r,
      monitored: true,
      monitorNewItems: "none",
      addOptions: {
        monitor: "specificAlbum",
        searchForMissingAlbums: false
      }
    })
  }')

resp=$(curl -fsS -X POST -H "X-Api-Key: $KEY" -H "Content-Type: application/json" \
  -d "$payload" "$URL/api/v1/album") \
  || { err "add failed"; exit 1; }

err "Added: $(echo "$resp" | jq -r '"\(.artist.artistName) — \(.title)"')"
