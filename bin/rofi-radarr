#!/usr/bin/env bash
# Search Radarr and add a movie.
#
# Env:
#   ROFI_RADARR_URL      (default: http://localhost:7878)
#   ROFI_RADARR_API_KEY  (optional; falls back to `pass show Home/RadarrAPI`)
set -euo pipefail

URL="${ROFI_RADARR_URL:-http://localhost:7878}"
KEY="${ROFI_RADARR_API_KEY:-$(pass show Home/RadarrAPI 2>/dev/null || true)}"

err() { notify-send "rofi-radarr" "$1" 2>/dev/null || echo "$1" >&2; }

[ -n "$KEY" ] || { err "no API key (set ROFI_RADARR_API_KEY or run: pass insert Home/RadarrAPI)"; exit 1; }

api() { curl -fsSk -H "X-Api-Key: $KEY" "$@"; }

query=$(rofi -dmenu -p "Radarr search" </dev/null || true)
[ -n "$query" ] || exit 0

results=$(api -G --data-urlencode "term=$query" "$URL/api/v3/movie/lookup") \
  || { err "lookup failed"; exit 1; }

choices=$(echo "$results" | jq -r '
  to_entries[] |
  "\(.value.title) (\(.value.year // "?"))\t\(.key)"')

[ -n "$choices" ] || { err "no results"; exit 0; }

picked=$(printf '%s\n' "$choices" | rofi -dmenu -i -matching fuzzy -p "Add" \
  -display-columns 1 -display-column-separator '\t' || true)
[ -n "$picked" ] || exit 0

idx=$(printf '%s' "$picked" | awk -F'\t' '{print $NF}')

qpid=$(api "$URL/api/v3/qualityprofile" | jq '.[0].id')
root=$(api "$URL/api/v3/rootfolder" | jq -r '.[0].path')

payload=$(echo "$results" | jq --argjson i "$idx" --argjson q "$qpid" --arg r "$root" '
  .[$i] + {
    qualityProfileId: $q,
    rootFolderPath: $r,
    monitored: true,
    minimumAvailability: "released",
    addOptions: {
      searchForMovie: true,
      monitor: "movieOnly"
    }
  }')

resp=$(curl -fsSk -X POST -H "X-Api-Key: $KEY" -H "Content-Type: application/json" \
  -d "$payload" "$URL/api/v3/movie") \
  || { err "add failed: $(echo "$payload" | jq -r '.title')"; exit 1; }

err "Added: $(echo "$resp" | jq -r '.title')"
